# Configuration de l'environnement pour le projet d'analyse immobilière (Exemple)

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=real_estate_db

# Dagster Home (Mettre le chemin absolu vers le dossier .dagster de votre projet)
DAGSTER_HOME=./.dagster
